{
  "project": "KOHEE LIST",
  "authModelTarget": "admin_user",
  "legacyRoles": [
    "manager"
  ],
  "sourceOfTruth": "docs/KOHEE_MASTER_CONTEXT.md",
  "automation": {
    "operatingModel": "chatgpt_main",
    "executor": "ChatGPT GitHub connector",
    "validationGate": "GitHub Actions",
    "codexRole": [
      "reviewer",
      "analysis",
      "PATCH_READY support"
    ],
    "githubAppWorkerRole": "future GitHub execution layer; dry-run until explicitly promoted",
    "trusts": [
      "actual PR URL",
      "head SHA",
      "changed files",
      "checks",
      "review threads",
      "workflow results",
      "issue state"
    ],
    "doesNotTrustWithoutGitHubEvidence": [
      "Codex Cloud self-report",
      "local branch name",
      "local commit claim",
      "make_pr metadata without actual PR URL"
    ],
    "phase2Connection": {
      "status": "deferred_until_user_explicitly_starts",
      "mustRunFrom": "local authenticated gh/wrangler environment",
      "mustNotRunFrom": "Codex Cloud",
      "dryRunOnly": true,
      "noWriteActions": true,
      "noIssueClose": true,
      "noAutoMerge": true
    }
  },
  "parallelExecution": {
    "defaultFor": [
      "LOW",
      "MEDIUM"
    ],
    "mergePolicy": "sequential_after_checks_and_review_threads",
    "allowedWhen": [
      "files_do_not_overlap",
      "risk_areas_do_not_overlap",
      "no_shared_test_file_overlap",
      "not_high_or_hold",
      "explicit_merge_order_exists"
    ],
    "denyWhen": [
      "HIGH_or_HOLD",
      "D1_schema_migrations",
      "auth_session_security",
      "public_data_or_public_api_behavior",
      "CSV_import_reset_semantics",
      "destructive_data_behavior",
      "production_deploy_workflow_or_secrets",
      "GitHub_App_Cloudflare_control_plane_connection",
      "manager_role_removal_shared_auth_server_tests",
      "same_file_overlap"
    ]
  },
  "invariants": {
    "publicCafeWhere": "status = 'approved' AND deleted_at IS NULL",
    "newCafeDefaultStatus": "candidate",
    "publicApprovalGate": "approveCafe",
    "holdDefinition": "status = 'hidden' AND hidden_at IS NOT NULL",
    "legacyHiddenDefinition": "status = 'hidden' AND hidden_at IS NULL",
    "csvApprovedStagesAs": "candidate",
    "csvHiddenStagesAs": "hidden_with_hidden_at",
    "resetCsvSafeError": "CSV reset failed"
  },
  "lanes": {
    "PUBLIC_EXPOSURE": {
      "purpose": "Prevent candidate, hidden, rejected, or deleted cafes from public/user exposure.",
      "files": [
        "server/cafes.js",
        "server/favorites.js",
        "assets/index.js",
        "assets/mypage.js",
        "scripts/test-unit.mjs"
      ]
    },
    "AUTH_ROLE": {
      "purpose": "Authentication, CSRF, roles, admin/user authorization, and manager removal.",
      "files": [
        "server/routes.js",
        "server/shared.js",
        "server/auth.js",
        "server/security.js",
        "server/users.js",
        "assets/admin.js",
        "scripts/test-unit.mjs"
      ]
    },
    "LIFECYCLE": {
      "purpose": "Cafe lifecycle transitions: candidate, hold, approved, deleted, restore.",
      "files": [
        "server/cafes.js",
        "server/csv.js",
        "server/submissions.js",
        "server/favorites.js",
        "schema.sql",
        "scripts/test-unit.mjs",
        "docs/DATA_LIFECYCLE_PLAN.md"
      ]
    },
    "CSV_PIPELINE": {
      "purpose": "CSV import, reset, rollback, review exports, and future reviewed import staging.",
      "files": [
        "server/csv.js",
        "server/cafes.js",
        "server/submissions.js",
        "assets/admin.js",
        "scripts/test-unit.mjs",
        "docs/DATA_LIFECYCLE_PLAN.md"
      ]
    },
    "FRONTEND_RENDERING": {
      "purpose": "Frontend rendering safety, admin/mypage/index UI, XSS-safe DOM updates, and external links.",
      "files": [
        "assets/common.js",
        "assets/index.js",
        "assets/mypage.js",
        "assets/admin.js",
        "index.html",
        "mypage.html",
        "admin.html",
        "submit.html",
        "login.html",
        ".pages-deploy"
      ]
    },
    "DEPLOY_SAFETY": {
      "purpose": "GitHub Actions, Cloudflare deploy safety, D1 migration blocking, repo safety, and deploy sync.",
      "files": [
        "package.json",
        "scripts",
        ".github/workflows",
        "_headers",
        ".pages-deploy/_headers",
        "wrangler.toml"
      ]
    },
    "GOVERNANCE": {
      "purpose": "Repository governance, agent contracts, GitHub command bridge templates, findings ledger, and governance validation tooling.",
      "files": [
        "AGENTS.md",
        "kohee.contract.json",
        "docs/KOHEE_MASTER_CONTEXT.md",
        "docs/CODEX_WORKFLOW.md",
        "docs/CODEX_AUTOMATION_STATUS.md",
        "docs/audits/KOHEE_FINDINGS.md",
        ".github/pull_request_template.md",
        ".github/ISSUE_TEMPLATE",
        "scripts/audit-kohee.mjs",
        "package.json"
      ]
    }
  },
  "verify": {
    "LOW": [
      "npm run check:deploy-sync",
      "npm run test:unit",
      "git diff --check"
    ],
    "MEDIUM": [
      "npm run check:deploy-sync",
      "npm run test:unit",
      "powershell -ExecutionPolicy Bypass -File .\\scripts\\check-syntax.ps1",
      "npm run format:check",
      "git diff --check"
    ],
    "HIGH": [
      "npm run check:deploy-sync",
      "npm run test:unit",
      "powershell -ExecutionPolicy Bypass -File .\\scripts\\check-syntax.ps1",
      "npm run verify:release",
      "npm run format:check",
      "git diff --check",
      "npm run check:repo-safety"
    ]
  },
  "reportFormat": [
    "Risk",
    "Lane",
    "Commit or PR",
    "Changed files",
    "Changed functions",
    "Tests",
    "Remaining risks"
  ],
  "forbidden": [
    "broad refactor",
    "manager expansion",
    "aaa/aaaa changes",
    "deploy unless explicitly requested",
    "changes outside allowlist"
  ]
}
