/*
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' https://cdn.jsdelivr.net; img-src 'self' data: https:; connect-src 'self' https://kohee-list.gabefinder.workers.dev; font-src 'self' https://cdn.jsdelivr.net data:; object-src 'none'; base-uri 'none'; frame-ancestors 'none'; form-action 'self'
